<UserControl x:Class="NrgOverlay.App.Settings.OverrideRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <!--
        Stream-override row layout:
            [вђ Custom] [Label 100px] [Content]
        When HasOverride=false the "Custom" checkbox is unchecked and the
        content area is visually greyed (the hosted control is disabled
        via IsEnabled binding in the parent XAML вЂ” we just dim here).
    -->
    <StackPanel Orientation="Horizontal" Margin="0,2">

        <!-- "Custom" toggle -->
        <CheckBox IsChecked="{Binding HasOverride, ElementName=Root}"
                  Content="Custom"
                  Width="70"
                  VerticalAlignment="Center"
                  Margin="0,0,6,0"
                  FontSize="11"/>

        <!-- Label -->
        <TextBlock x:Name="LabelBlock"
                   Width="100"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>

        <!-- Content slot вЂ” opacity dims when not overriding -->
        <StackPanel x:Name="ContentSlot"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasOverride, ElementName=Root}" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
        </StackPanel>

    </StackPanel>
</UserControl>

