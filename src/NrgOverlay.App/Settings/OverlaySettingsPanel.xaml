<UserControl x:Class="NrgOverlay.App.Settings.OverlaySettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NrgOverlay.App.Settings">

    <UserControl.Resources>
        <!-- Row label style -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="130"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <!-- Section header -->
        <Style x:Key="SectionHdr" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <!-- Inline color editor: [в– ] R G B A -->
        <Style x:Key="ChBox" TargetType="TextBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <!-- Override row: checkbox + content (greyed when unchecked) -->
        <Style x:Key="OverrideRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <TabControl x:Name="Tabs" Margin="0">

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <!-- TAB 1: Screen (base config)                                       -->
        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <TabItem Header="Screen">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="ScreenPanel"
                            LostFocus="ScreenPanel_LostFocus">

                    <!-- Position & Size -->
                    <TextBlock Text="Position &amp; Size" Style="{StaticResource SectionHdr}"/>
                    <local:FieldRow Label="X" >
                        <TextBox Text="{Binding X, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Y">
                        <TextBox Text="{Binding Y, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Width">
                        <TextBox Text="{Binding Width, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Height">
                        <TextBox Text="{Binding Height, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>

                    <!-- Appearance -->
                    <TextBlock Text="Appearance" Style="{StaticResource SectionHdr}"/>
                    <local:FieldRow Label="Font Size (px)">
                        <TextBox Text="{Binding FontSize, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Opacity (0вЂ“1)">
                        <Slider Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                Value="{Binding Opacity}" Width="140"
                                ValueChanged="Slider_Changed"/>
                        <TextBlock Text="{Binding Opacity, StringFormat='{}{0:F2}'}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Background">
                        <local:ColorEditor DataContext="{Binding BackgroundColor}"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Text">
                        <local:ColorEditor DataContext="{Binding TextColor}"/>
                    </local:FieldRow>

                    <!-- Relative-specific -->
                    <StackPanel x:Name="RelativeSection">
                        <TextBlock Text="Relative Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="Player Highlight">
                            <local:ColorEditor DataContext="{Binding PlayerHighlightColor}"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Max Drivers">
                            <TextBox Text="{Binding MaxDriversShown, UpdateSourceTrigger=LostFocus}" Width="70"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show iRating column"
                                      IsChecked="{Binding ShowIRating}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show License column"
                                      IsChecked="{Binding ShowLicense}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                    </StackPanel>

                    <!-- Session Info-specific -->
                    <StackPanel x:Name="SessionSection">
                        <TextBlock Text="Session Info Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show weather" IsChecked="{Binding ShowWeather}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show delta" IsChecked="{Binding ShowDelta}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show game time" IsChecked="{Binding ShowGameTime}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Use 12-hour clock" IsChecked="{Binding Use12HourClock}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Temperature">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Celsius"    GroupName="TempUnit" Margin="0,0,12,0"
                                             IsChecked="{Binding TemperatureUnit,
                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                 ConverterParameter=Celsius}"
                                             Checked="Toggle_Changed"/>
                                <RadioButton Content="Fahrenheit" GroupName="TempUnit"
                                             IsChecked="{Binding TemperatureUnit,
                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                 ConverterParameter=Fahrenheit}"
                                             Checked="Toggle_Changed"/>
                            </StackPanel>
                        </local:FieldRow>
                    </StackPanel>

                    <!-- Delta Bar-specific -->
                    <StackPanel x:Name="DeltaSection">
                        <TextBlock Text="Delta Bar Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="Max Delta (sec)">
                            <TextBox Text="{Binding DeltaBarMaxSeconds, UpdateSourceTrigger=LostFocus}"
                                     Width="70"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Faster Color">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding FasterColor}"/>
                                <TextBox Text="{Binding FasterColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"/>
                            </StackPanel>
                        </local:FieldRow>
                        <local:FieldRow Label="Slower Color">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding SlowerColor}"/>
                                <TextBox Text="{Binding SlowerColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"/>
                            </StackPanel>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show trend arrow" IsChecked="{Binding ShowTrendArrow}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show delta text" IsChecked="{Binding ShowDeltaText}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show reference lap time" IsChecked="{Binding ShowReferenceLapTime}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <!-- TAB 2: Stream Override                                            -->
        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <TabItem Header="Stream Override">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel DataContext="{Binding StreamOverride}"
                            LostFocus="ScreenPanel_LostFocus">

                    <CheckBox Content="Enable stream override for this overlay"
                              IsChecked="{Binding Enabled}"
                              FontWeight="SemiBold" Margin="0,4,0,8"
                              Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>

                    <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,8"
                               Text="Position (X/Y) is never overridden вЂ” it is always shared."/>

                    <!-- Override rows: [вђ Custom] label: control -->
                    <local:OverrideRow Label="Width"   HasOverride="{Binding HasWidth}">
                        <TextBox Text="{Binding Width, UpdateSourceTrigger=LostFocus}" Width="70"
                                 IsEnabled="{Binding HasWidth}"/>
                    </local:OverrideRow>
                    <local:OverrideRow Label="Height"  HasOverride="{Binding HasHeight}">
                        <TextBox Text="{Binding Height, UpdateSourceTrigger=LostFocus}" Width="70"
                                 IsEnabled="{Binding HasHeight}"/>
                    </local:OverrideRow>
                    <local:OverrideRow Label="Opacity" HasOverride="{Binding HasOpacity}">
                        <Slider Minimum="0" Maximum="1" Value="{Binding Opacity}"
                                Width="120" IsEnabled="{Binding HasOpacity}"
                                ValueChanged="Slider_Changed"/>
                    </local:OverrideRow>
                    <local:OverrideRow Label="Font Size" HasOverride="{Binding HasFontSize}">
                        <TextBox Text="{Binding FontSize, UpdateSourceTrigger=LostFocus}" Width="70"
                                 IsEnabled="{Binding HasFontSize}"/>
                    </local:OverrideRow>
                    <local:OverrideRow Label="Background" HasOverride="{Binding HasBackgroundColor}">
                        <local:ColorEditor DataContext="{Binding BackgroundColor}"
                                           IsEnabled="{Binding DataContext.HasBackgroundColor,
                                               RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                    </local:OverrideRow>
                    <local:OverrideRow Label="Text Color" HasOverride="{Binding HasTextColor}">
                        <local:ColorEditor DataContext="{Binding TextColor}"
                                           IsEnabled="{Binding DataContext.HasTextColor,
                                               RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                    </local:OverrideRow>

                    <!-- Overlay-specific overrides wired in code-behind -->
                    <StackPanel x:Name="SoRelative">
                        <local:OverrideRow Label="Show iRating" HasOverride="{Binding HasShowIRating}">
                            <CheckBox IsChecked="{Binding ShowIRating}" IsEnabled="{Binding HasShowIRating}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Show License" HasOverride="{Binding HasShowLicense}">
                            <CheckBox IsChecked="{Binding ShowLicense}" IsEnabled="{Binding HasShowLicense}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Max Drivers"  HasOverride="{Binding HasMaxDriversShown}">
                            <TextBox Text="{Binding MaxDriversShown, UpdateSourceTrigger=LostFocus}" Width="70"
                                     IsEnabled="{Binding HasMaxDriversShown}"/>
                        </local:OverrideRow>
                    </StackPanel>

                    <StackPanel x:Name="SoSession">
                        <local:OverrideRow Label="Show Weather" HasOverride="{Binding HasShowWeather}">
                            <CheckBox IsChecked="{Binding ShowWeather}" IsEnabled="{Binding HasShowWeather}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Show Delta"   HasOverride="{Binding HasShowDelta}">
                            <CheckBox IsChecked="{Binding ShowDelta}" IsEnabled="{Binding HasShowDelta}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:OverrideRow>
                    </StackPanel>

                    <StackPanel x:Name="SoDelta">
                        <local:OverrideRow Label="Max Secs"   HasOverride="{Binding HasDeltaBarMaxSeconds}">
                            <TextBox Text="{Binding DeltaBarMaxSeconds, UpdateSourceTrigger=LostFocus}" Width="70"
                                     IsEnabled="{Binding HasDeltaBarMaxSeconds}"/>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Faster Color" HasOverride="{Binding HasFasterColor}">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding FasterColor}"
                                                   IsEnabled="{Binding DataContext.HasFasterColor,
                                                       RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                                <TextBox Text="{Binding FasterColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"
                                         IsEnabled="{Binding DataContext.HasFasterColor,
                                             RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                            </StackPanel>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Slower Color" HasOverride="{Binding HasSlowerColor}">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding SlowerColor}"
                                                   IsEnabled="{Binding DataContext.HasSlowerColor,
                                                       RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                                <TextBox Text="{Binding SlowerColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"
                                         IsEnabled="{Binding DataContext.HasSlowerColor,
                                             RelativeSource={RelativeSource AncestorType=local:OverrideRow}}"/>
                            </StackPanel>
                        </local:OverrideRow>
                        <local:OverrideRow Label="Show Ref Time" HasOverride="{Binding HasShowReferenceLapTime}">
                            <CheckBox IsChecked="{Binding ShowReferenceLapTime}" IsEnabled="{Binding HasShowReferenceLapTime}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:OverrideRow>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

    </TabControl>
</UserControl>

