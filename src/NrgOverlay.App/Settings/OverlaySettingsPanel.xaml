<UserControl x:Class="NrgOverlay.App.Settings.OverlaySettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NrgOverlay.App.Settings">

    <UserControl.Resources>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="130"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="SectionHdr" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style x:Key="ChBox" TargetType="TextBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
    </UserControl.Resources>

    <TabControl x:Name="Tabs" Margin="0">
        <TabItem Header="Screen">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="ScreenPanel"
                            LostFocus="ScreenPanel_LostFocus">

                    <TextBlock Text="Position &amp; Size" Style="{StaticResource SectionHdr}"/>
                    <local:FieldRow Label="X" >
                        <TextBox Text="{Binding X, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Y">
                        <TextBox Text="{Binding Y, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Width">
                        <TextBox Text="{Binding Width, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Height">
                        <TextBox Text="{Binding Height, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>

                    <TextBlock Text="Appearance" Style="{StaticResource SectionHdr}"/>
                    <local:FieldRow Label="Font Size (px)">
                        <TextBox Text="{Binding FontSize, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Opacity (0-1)">
                        <Slider Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                Value="{Binding Opacity}" Width="140"
                                ValueChanged="Slider_Changed"/>
                        <TextBlock Text="{Binding Opacity, StringFormat='{}{0:F2}'}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Background">
                        <local:ColorEditor DataContext="{Binding BackgroundColor}"/>
                    </local:FieldRow>
                    <local:FieldRow Label="Text">
                        <local:ColorEditor DataContext="{Binding TextColor}"/>
                    </local:FieldRow>

                    <StackPanel x:Name="RelativeSection">
                        <TextBlock Text="Relative Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="Player Highlight">
                            <local:ColorEditor DataContext="{Binding PlayerHighlightColor}"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Max Drivers">
                            <TextBox Text="{Binding MaxDriversShown, UpdateSourceTrigger=LostFocus}" Width="70"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show iRating column"
                                      IsChecked="{Binding ShowIRating}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show License column"
                                      IsChecked="{Binding ShowLicense}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                    </StackPanel>

                    <StackPanel x:Name="SessionSection">
                        <TextBlock Text="Session Info Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show weather" IsChecked="{Binding ShowWeather}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show delta" IsChecked="{Binding ShowDelta}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show game time" IsChecked="{Binding ShowGameTime}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Use 12-hour clock" IsChecked="{Binding Use12HourClock}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Temperature">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Celsius" GroupName="TempUnit" Margin="0,0,12,0"
                                             IsChecked="{Binding TemperatureUnit,
                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                 ConverterParameter=Celsius}"
                                             Checked="Toggle_Changed"/>
                                <RadioButton Content="Fahrenheit" GroupName="TempUnit"
                                             IsChecked="{Binding TemperatureUnit,
                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                 ConverterParameter=Fahrenheit}"
                                             Checked="Toggle_Changed"/>
                            </StackPanel>
                        </local:FieldRow>
                    </StackPanel>

                    <StackPanel x:Name="DeltaSection">
                        <TextBlock Text="Delta Bar Options" Style="{StaticResource SectionHdr}"/>
                        <local:FieldRow Label="Max Delta (sec)">
                            <TextBox Text="{Binding DeltaBarMaxSeconds, UpdateSourceTrigger=LostFocus}"
                                     Width="70"/>
                        </local:FieldRow>
                        <local:FieldRow Label="Faster Color">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding FasterColor}"/>
                                <TextBox Text="{Binding FasterColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"/>
                            </StackPanel>
                        </local:FieldRow>
                        <local:FieldRow Label="Slower Color">
                            <StackPanel Orientation="Horizontal">
                                <local:ColorEditor DataContext="{Binding SlowerColor}"/>
                                <TextBox Text="{Binding SlowerColor.HexRgb, UpdateSourceTrigger=LostFocus}"
                                         Width="90" Margin="8,0,0,0"/>
                            </StackPanel>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show trend arrow" IsChecked="{Binding ShowTrendArrow}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show delta text" IsChecked="{Binding ShowDeltaText}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                        <local:FieldRow Label="">
                            <CheckBox Content="Show reference lap time" IsChecked="{Binding ShowReferenceLapTime}"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </local:FieldRow>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
