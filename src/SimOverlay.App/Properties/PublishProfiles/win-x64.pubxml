<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish for Windows x64.

  Usage:
    dotnet publish src/SimOverlay.App -p:PublishProfile=win-x64

  Output: src/SimOverlay.App/bin/publish/win-x64/
  The resulting SimOverlay.App.exe runs without a .NET 8 runtime installed.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishDir>bin\publish\win-x64\</PublishDir>
    <!-- Keep .pdb outside the bundle so crash stacks are symbolicated without recompiling -->
    <DebugType>pdbonly</DebugType>
  </PropertyGroup>
</Project>
