<UserControl x:Class="SimOverlay.App.Settings.ColorEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Compact inline color editor: [■ swatch] R [box] G [box] B [box] A [box]
        Bind DataContext to a ColorViewModel.
    -->
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

        <!-- Swatch -->
        <Border Width="18" Height="18"
                BorderBrush="#888" BorderThickness="1"
                Margin="0,0,6,0" VerticalAlignment="Center">
            <Rectangle Fill="{Binding PreviewBrush}"/>
        </Border>

        <TextBlock Text="R" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
        <TextBox Text="{Binding R, UpdateSourceTrigger=LostFocus}"
                 Width="38" Margin="0,0,4,0"/>

        <TextBlock Text="G" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
        <TextBox Text="{Binding G, UpdateSourceTrigger=LostFocus}"
                 Width="38" Margin="0,0,4,0"/>

        <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
        <TextBox Text="{Binding B, UpdateSourceTrigger=LostFocus}"
                 Width="38" Margin="0,0,4,0"/>

        <TextBlock Text="A" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11"/>
        <TextBox Text="{Binding A, UpdateSourceTrigger=LostFocus}"
                 Width="38"/>
    </StackPanel>
</UserControl>
