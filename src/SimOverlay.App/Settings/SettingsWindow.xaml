<Window x:Class="SimOverlay.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimOverlay.App.Settings"
        Title="SimOverlay Settings"
        Width="720" Height="560"
        MinWidth="580" MinHeight="420"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="10,10,8,2"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Footer ────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#DDD">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ApplyBtn" Content="Apply" Width="80" Click="Apply_Click"
                        IsDefault="True" Margin="0,0,8,0"/>
                <Button Content="Close"   Width="80" Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Main area: sidebar + content ──────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="130"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <DockPanel Grid.Column="0" Background="#F7F7F7">

                <TextBlock DockPanel.Dock="Top" Text="OVERLAYS"
                           Style="{StaticResource SectionHeader}"/>

                <!-- Overlay nav list (top portion) -->
                <ListBox x:Name="OverlayNavList"
                         BorderThickness="0" Background="Transparent"
                         SelectionChanged="OverlayNavList_SelectionChanged"
                         DockPanel.Dock="Top">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavItem}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"/>
                                <CheckBox  Grid.Column="1" IsChecked="{Binding IsEnabled}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                           ToolTip="Enable / disable overlay"
                                           Click="OverlayEnabled_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Separator DockPanel.Dock="Top" Margin="8,4"/>

                <TextBlock DockPanel.Dock="Top" Text="GLOBAL"
                           Style="{StaticResource SectionHeader}"/>

                <!-- Global Settings nav -->
                <ListBox x:Name="GlobalNavList"
                         BorderThickness="0" Background="Transparent"
                         SelectionChanged="GlobalNavList_SelectionChanged"
                         DockPanel.Dock="Top">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavItem}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="Global Settings" Tag="global"/>
                </ListBox>

            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#DDD" ResizeBehavior="PreviousAndNext"/>

            <!-- Content panel -->
            <ContentControl x:Name="ContentArea" Grid.Column="2"
                            Margin="0" VerticalContentAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"/>
        </Grid>
    </DockPanel>
</Window>
