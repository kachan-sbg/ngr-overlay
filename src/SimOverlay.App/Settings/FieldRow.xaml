<UserControl x:Class="SimOverlay.App.Settings.FieldRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        A labelled row: [Label 130px] [Content (child elements)]
        Set Label="..." as an attribute on the control.
        Child elements go inside the tag and are placed in ContentSlot.
    -->
    <StackPanel Orientation="Horizontal" Margin="0,2">
        <TextBlock x:Name="LabelBlock"
                   Width="130"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
        <StackPanel x:Name="ContentSlot"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>
